		{
			"name": "Generate CSRF token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const jsonData = pm.response.json();\r",
							"\r",
							"const newCsrfToken = jsonData.csrfToken;\r",
							"\r",
							"pm.collectionVariables.set(\"csrf-token\", newCsrfToken);\r",
							"\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
