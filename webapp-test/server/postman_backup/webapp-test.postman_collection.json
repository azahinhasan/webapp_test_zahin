		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const jsonData = pm.response.json();\r",
							"\r",
							"const accessToken = jsonData.accessToken;\r",
							"\r",
							"pm.collectionVariables.set(\"token\", accessToken);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
